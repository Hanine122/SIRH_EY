@{
    ViewData["Title"] = "Tableau de bord";
    var recents = ViewBag.CollaborateursRecents as List<dynamic> ?? new List<dynamic>();
    var formations = ViewBag.FormationsEnCours as List<dynamic> ?? new List<dynamic>();
}

<div class="row portal-wrapper g-4">
    <!-- LEFT COLUMN: Workspace -->
    <div class="col-lg-8 portal-left">
        
        <!-- 1. Hero Section -->
        <div class="hero-banner glass-panel p-4 mb-2">
            <div class="hero-content">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="h3 fw-bold mb-0">Bonjour, @(ViewBag.PrenomConnecte ?? "Collaborateur")</h1>
                    <div class="small opacity-75">
                        @DateTime.Now.ToString("dd MMMM", new System.Globalization.CultureInfo("fr-FR"))
                    </div>
                </div>
                <p class="mb-4 opacity-75" style="max-width: 500px;">
                    Bienvenue sur votre espace SIRH EY. Consultez vos activités récentes, suivez vos objectifs et développez vos compétences.
                </p>
                <div class="d-flex flex-wrap gap-2 mt-2">
                    <span class="chip"><i class="fas fa-book-open"></i> @(ViewBag.NbFormationsSuivies ?? 0) Formations en cours</span>
                    <span class="chip"><i class="fas fa-check-circle"></i> @(ViewBag.TauxCompletion ?? 0)% Compétences</span>
                    <span class="chip"><i class="fas fa-bolt"></i> Actions RH</span>
                </div>
            </div>
        </div>

        <!-- 2. KPI Cards -->
        <div class="row g-3 mb-2">
            <div class="col-md-4">
                <div class="glass-panel kpi-card kpi-card-actives">
                    <i class="fas fa-users kpi-icon"></i>
                    <div class="kpi-label mb-1">COLLABORATEURS ACTIFS</div>
                    <div class="kpi-value">@ViewBag.NbCollaborateursActifs</div>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small text-success fw-semibold"><i class="fas fa-arrow-up"></i> 12%</span>
                    </div>
                    <div class="progress-animated mt-2"><div class="progress-bar" style="width: 78%"></div></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel kpi-card kpi-card-trainings">
                    <i class="fas fa-graduation-cap kpi-icon"></i>
                    <div class="kpi-label mb-1">FORMATIONS SUIVIES</div>
                    <div class="kpi-value">@ViewBag.NbFormationsSuivies</div>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small text-muted fw-semibold">Stable</span>
                    </div>
                    <div class="progress-animated mt-2"><div class="progress-bar" style="width: 46%"></div></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel kpi-card kpi-card-completion">
                    <i class="fas fa-chart-pie kpi-icon"></i>
                    <div class="kpi-label mb-1">TAUX DE COMPLÉTION</div>
                    <div class="kpi-value">@ViewBag.TauxCompletion%</div>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small text-success fw-semibold"><i class="fas fa-arrow-up"></i> 5%</span>
                    </div>
                    <div class="progress-animated mt-2"><div class="progress-bar" style="width: @ViewBag.TauxCompletion%"></div></div>
                </div>
            </div>
        </div>

        <!-- 3. Quick Actions -->
        <h5 class="fw-bold mb-3 mt-2">Actions rapides</h5>
        <div class="row g-3">
            <div class="col-6 col-sm-4 col-md-2 flex-grow-1">
                <a asp-controller="Collaborateurs" asp-action="Index" class="glass-panel quick-action-card">
                    <div class="icon-bubble"><i class="fas fa-users"></i></div>
                    <h6>Voir mon équipe</h6>
                    <small>Annuaire et infos</small>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2 flex-grow-1">
                <a asp-controller="Formations" asp-action="Index" class="glass-panel quick-action-card">
                    <div class="icon-bubble"><i class="fas fa-graduation-cap"></i></div>
                    <h6>Mes formations</h6>
                    <small>Catalogue et suivi</small>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2 flex-grow-1">
                <a asp-controller="Competences" asp-action="Index" class="glass-panel quick-action-card">
                    <div class="icon-bubble"><i class="fas fa-chart-bar"></i></div>
                    <h6>Mes compétences</h6>
                    <small>Cartographie</small>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2 flex-grow-1">
                <a asp-controller="Progression" asp-action="Index" class="glass-panel quick-action-card">
                    <div class="icon-bubble"><i class="fas fa-tachometer-alt"></i></div>
                    <h6>Mon évolution</h6>
                    <small>Entretiens et KPI</small>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2 flex-grow-1">
                <a asp-controller="Objectives" asp-action="Index" class="glass-panel quick-action-card">
                    <div class="icon-bubble"><i class="fas fa-bullseye"></i></div>
                    <h6>Mes objectifs RH</h6>
                    <small>Suivi annuel</small>
                </a>
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN: Activity Panel -->
    <div class="col-lg-4 portal-right">
        <div class="portal-right-panel p-4 h-100">
            <h5 class="panel-title">Mon espace</h5>

            <!-- AI Widget -->
            <div class="ai-insight-card mb-4">
                <div class="ai-pulse-border"></div>
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="ai-icon-bubble">
                        <i class="fas fa-magic"></i>
                    </div>
                    <span class="confidence-badge">Impact estimé +15%</span>
                </div>
                <h6 class="fw-bold text-white mb-2">Recommandation personnalisée</h6>
                <p class="small text-white-50 mb-0">
                    Excellente progression ce trimestre ! En complétant la certification <strong>"Leadership Avancé"</strong>, vous augmenterez significativement votre score d'évolution.
                </p>
            </div>

            <!-- Deadlines Timeline -->
            <div class="mb-4">
                <h6 class="panel-section-title">Échéances à venir</h6>
                <div class="timeline-container">
                    <div class="timeline-item">
                        <div class="timeline-dot dot-high"></div>
                        <div class="timeline-card">
                            <h6 class="mb-1 text-white" style="font-size: 0.85rem;">Bilan de mi-année</h6>
                            <div class="small text-danger fw-semibold"><i class="fas fa-exclamation-circle me-1"></i>Dans 5 jours (15 Juin)</div>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot dot-med"></div>
                        <div class="timeline-card">
                            <h6 class="mb-1 text-white" style="font-size: 0.85rem;">Formations à venir</h6>
                            <div class="small text-warning"><i class="far fa-clock me-1"></i>Dans 12 jours</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Formations (reusing ViewBag data) -->
            <div class="mb-4">
                <h6 class="panel-section-title">Formations en cours</h6>
                @if (!formations.Any())
                {
                    <div class="text-white-50 small">Aucune formation en cours.</div>
                }
                else
                {
                    @foreach (var formation in formations.Take(3))
                    {
                        <div class="mini-training-card">
                            <div class="circular-progress-wrap" style="--p: @formation.Progression%;">
                                <div class="circular-progress-inner">@formation.Progression%</div>
                            </div>
                            <div class="flex-grow-1 min-width-0">
                                <h6 class="mb-1 text-white text-truncate" style="font-size: 0.85rem;">@formation.Titre</h6>
                                <div class="small text-white-50">Reste @formation.JoursRestants jours</div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Certifications -->
            <div class="mb-4">
                <h6 class="panel-section-title">Dernières certifications</h6>
                <div>
                    <span class="cert-chip"><i class="fas fa-medal text-warning"></i> Agile Scrum</span>
                    <span class="cert-chip"><i class="fas fa-medal text-warning"></i> Data Analytics</span>
                    <span class="cert-chip"><i class="fas fa-certificate text-secondary"></i> RGPD Base</span>
                </div>
            </div>

            <!-- Manager Feedback -->
            <div class="mb-2">
                <h6 class="panel-section-title">Retour Manager</h6>
                <div class="quote-card">
                    <div class="fst-italic text-white-50 small mb-2">"Très bonne implication sur la formation Leadership."</div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="manager-avatar">SD</div>
                        <div class="small text-white fw-semibold">Ibtissem B., Manager</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
 