@{
    ViewData["Title"] = "Tableau de bord";
    var recents = ViewBag.CollaborateursRecents as List<dynamic> ?? new List<dynamic>();
    var formations = ViewBag.FormationsEnCours as List<dynamic> ?? new List<dynamic>();
}

<div class="ey-dark-hero ey-card mb-4">
    <div class="row g-3 align-items-center">
        <div class="col-lg-8">
            <h1 class="mb-2 fw-bold">Bonjour, @(ViewBag.PrenomConnecte ?? "Collaborateur")</h1>
            <p class="mb-0 text-white-50">Bienvenue sur votre espace SIRH EY. Voici un aperçu de vos activités aujourd'hui.</p>
        </div>
        <div class="col-lg-4 text-lg-end">
            <div class="ey-date-badge">
    <div class="ey-date-label">AUJOURD'HUI</div>
    <div class="ey-date-value">
        @DateTime.Now.ToString("dd MMMM", new System.Globalization.CultureInfo("fr-FR"))
    </div>
</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="ey-card ey-kpi">
            <div class="d-flex justify-content-between mb-2">
                <div class="text-muted">COLLABORATEURS ACTIFS</div>
                <div class="small text-success fw-semibold">+12%</div>
            </div>
            <div class="ey-kpi-value">@ViewBag.NbCollaborateursActifs</div>
            <div class="ey-progress mt-3"><span style="width:78%"></span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ey-card ey-kpi">
            <div class="d-flex justify-content-between mb-2">
                <div class="text-muted">FORMATIONS SUIVIES</div>
                <div class="small text-muted fw-semibold">0%</div>
            </div>
            <div class="ey-kpi-value">@ViewBag.NbFormationsSuivies</div>
            <div class="ey-progress mt-3"><span style="width:46%;background:#9ca3af;"></span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ey-card ey-kpi">
            <div class="d-flex justify-content-between mb-2">
                <div class="text-muted">TAUX DE COMPLÉTION</div>
                <div class="small text-success fw-semibold">+5%</div>
            </div>
            <div class="ey-kpi-value">@ViewBag.TauxCompletion%</div>
            <div class="ey-progress mt-3"><span style="width:@ViewBag.TauxCompletion%"></span></div>
        </div>
    </div>
</div>

<div class="ey-card p-3 mb-4">
    <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="text-muted">ACTIONS RAPIDES</span>
        <a asp-controller="Collaborateurs" asp-action="Create" class="ey-btn-main text-decoration-none">
            <i class="fas fa-user-plus me-1"></i> Nouveau collaborateur
        </a>
        <a asp-controller="Formations" asp-action="Create" class="ey-btn-main text-decoration-none">
            <i class="fas fa-graduation-cap me-1"></i> Nouvelle formation
        </a>
        <a asp-controller="Collaborateurs" asp-action="Index" class="ms-auto text-decoration-none fw-semibold">Voir tout <i class="fas fa-arrow-right"></i></a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="ey-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <h4 class="mb-0">Module Core RH</h4>
                    <small class="text-muted">Gestion des effectifs et organigramme</small>
                </div>
                <a asp-controller="Collaborateurs" asp-action="Index" class="ey-btn-main text-decoration-none">Accéder</a>
            </div>

            <div class="table-responsive mt-3">
                <table class="table table-hover align-middle ey-rh-table mb-0 border-top">
                    <thead class="table-light text-muted small">
                        <tr>
                            <th class="ps-3 border-0 rounded-start">COLLABORATEUR</th>
                            <th class="border-0">GRADE</th>
                            <th class="border-0">ONBOARDING</th>
                            <th class="border-0">COMPLÉTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!recents.Any())
                        {
                            <tr><td colspan="4" class="text-muted text-center py-4">Aucun collaborateur.</td></tr>
                        }
                        else
                        {
                            @foreach (var collab in recents)
                            {
                                var daysSince = (DateTime.Now - (collab.DateEmbauche ?? DateTime.Now)).Days;
                                var isNew = daysSince <= 30;
                                var onboardingScore = Math.Min(100, Math.Max(0, (daysSince * 100) / 90)); // Simulate 90 days onboarding
                                var completionRate = Math.Min(100, 40 + (daysSince * 2)); // Simulate profile completion

                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            <div class="ey-box-avatar me-3 shadow-sm bg-dark text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-size: 0.9rem;">
                                                @(collab.Prenom?[0])@(collab.Nom?[0])
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark d-flex align-items-center gap-2">
                                                    @collab.Prenom @collab.Nom
                                                    @if (isNew) { <span class="badge bg-warning text-dark px-1 py-0" style="font-size: 0.65rem;">NOUVEAU</span> }
                                                </div>
                                                <div class="text-muted" style="font-size: 0.8rem;">@collab.Departement</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge border border-secondary text-secondary bg-transparent">@collab.Grade</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                <div class="progress-bar @(onboardingScore >= 100 ? "bg-success" : "bg-primary")" style="width: @onboardingScore%"></div>
                                            </div>
                                            <span class="small fw-bold @(onboardingScore >= 100 ? "text-success" : "text-muted")">@onboardingScore%</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                <div class="progress-bar @(completionRate >= 100 ? "bg-success" : "bg-warning")" style="width: @completionRate%"></div>
                                            </div>
                                            <span class="small fw-bold @(completionRate >= 100 ? "text-success" : "text-muted")">@completionRate%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="ey-card p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <h4 class="mb-0">Module Formations</h4>
                    <small class="text-muted">Programmes et certifications</small>
                </div>
                <a asp-controller="Formations" asp-action="Index" class="ey-btn-main text-decoration-none">Accéder</a>
            </div>

            <div class="mt-3">
                @if (!formations.Any())
                {
                    <div class="text-muted">Aucune formation en cours.</div>
                }
                else
                {
                    @foreach (var formation in formations.Take(4))
                    {
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <div>
                                <div class="fw-semibold">@formation.Titre</div>
                                <small class="text-muted">@formation.Progression% complété</small>
                            </div>
                            <small class="fw-semibold">Dans @formation.JoursRestants jours</small>
                        </div>
                    }
                }
            </div>
            <div class="alert alert-info mt-3 mb-0">
                Vous avez <strong>@ViewBag.NouvellesFormations</strong> nouvelles formations obligatoires assignées ce mois-ci.
            </div>
        </div>
    </div>
</div>