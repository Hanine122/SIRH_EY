@model SIRH.EY.Models.CertificatPdfModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Certificat de formation</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #fff;
        }
        .certificat {
            width: 100%;
            height: 100%;
            padding: 40px;
            border: 10px solid #FFD600;
            box-sizing: border-box;
            text-align: center;
        }
        .logo {
            margin-bottom: 30px;
        }
        .logo img {
            max-height: 60px;
        }
        .titre {
            font-size: 28px;
            font-weight: bold;
            margin: 20px 0;
            color: #000;
        }
        .sous-titre {
            font-size: 18px;
            margin: 10px 0;
            color: #333;
        }
        .nom {
            font-size: 24px;
            font-weight: bold;
            margin: 30px 0;
            color: #FFD600;
            background: #000;
            display: inline-block;
            padding: 10px 20px;
        }
        .details {
            margin: 20px 0;
            font-size: 16px;
            text-align: left;
            width: 80%;
            margin-left: auto;
            margin-right: auto;
        }
        .footer {
            margin-top: 40px;
            font-size: 12px;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="certificat">
        <div class="logo">
            <img src="https://www.ey.com/fr_fr/ui/assets/img/ey-logo.svg" alt="EY Logo" />
        </div>
        <div class="titre">CERTIFICAT DE FORMATION</div>
        <div class="sous-titre">Ce certificat est décerné à</div>
        <div class="nom">@Model.CollaborateurNom</div>
        <div class="details">
            <p><strong>Formation suivie :</strong> @Model.FormationTitre</p>
            <p><strong>Durée :</strong> @Model.Duree heures</p>
            <p><strong>Date d'obtention :</strong> @Model.DateObtention.ToString("dd/MM/yyyy")</p>
            <p><strong>Organisme :</strong> @Model.Organisme</p>
        </div>
        <div class="footer">
            EY SIRH- Bâtir un monde du travail plus perfor
        </div>
    </div>
</body>
</html>