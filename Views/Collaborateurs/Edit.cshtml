@model SIRH.EY.Models.Collaborateur
@{
    ViewData["Title"] = "Modifier collaborateur";
    var managers = ViewBag.Managers as List<SIRH.EY.Models.Collaborateur> ?? new List<SIRH.EY.Models.Collaborateur>();
    var departements = ViewBag.Departements as IReadOnlyList<string> ?? new[] { Model.Departement }.Where(d => !string.IsNullOrWhiteSpace(d)).Cast<string>().ToList();
    var postes = ViewBag.Postes as IReadOnlyList<string> ?? new[] { Model.Poste }.Where(p => !string.IsNullOrWhiteSpace(p)).Cast<string>().ToList();
}

<div class="ey-card p-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fas fa-pen me-1"></i> Modifier le profil</h5>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Retour</a>
    </div>
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nom"></label>
                <input asp-for="Nom" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Prenom"></label>
                <input asp-for="Prenom" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Departement" class="form-label"></label>
                <select asp-for="Departement" class="form-select js-departement-select" data-poste-target="#Poste">
                    <option value="">Selectionnez un departement</option>
                    @foreach (var departement in departements)
                    {
                        <option value="@departement">@departement</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="Poste" class="form-label"></label>
                <select asp-for="Poste" class="form-select js-poste-select">
                    <option value="">Selectionnez d'abord un departement</option>
                    @foreach (var poste in postes)
                    {
                        <option value="@poste">@poste</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="Grade" class="form-label"></label>
                <select asp-for="Grade" class="form-select">
                    <option value="">Sélectionnez un grade</option>
                    <option value="Junior">Junior</option>
                    <option value="Senior">Senior</option>
                    <option value="Manager">Manager</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Manager</label>
                <select asp-for="ManagerId" class="form-select">
                    <option value="">Aucun manager</option>
                    @foreach (var manager in managers)
                    {
                        <option value="@manager.Id">@manager.Prenom @manager.Nom</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="DateEmbauche"></label>
                <input asp-for="DateEmbauche" class="form-control" type="date" />
            </div>
            <div class="col-md-6">
                <div class="form-check mt-4">
                    <input asp-for="Actif" class="form-check-input" />
                    <label asp-for="Actif" class="form-check-label"></label>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="ey-btn-main">Enregistrer</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/rh-dynamic-forms.js" asp-append-version="true"></script>
}
