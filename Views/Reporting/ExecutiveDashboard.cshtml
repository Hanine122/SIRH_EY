@using System.Collections.Generic
@using SIRH.EY.Models
@{
    ViewData["Title"] = "Tableau de bord exécutif RH";
    var heatmapCollaborateurs = ViewBag.HeatmapCollaborateurs as List<Collaborateur> ?? new List<Collaborateur>();
    var heatmapCompetences = ViewBag.HeatmapCompetences as List<string> ?? new List<string>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/ey-analytics-dashboard.css" asp-append-version="true" />
}

<div class="ey-dashboard-container">
    <!-- Header Analytics -->
    <div class="ey-dashboard-header">
        <div class="ey-dashboard-title">
            <div class="ey-dashboard-icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <div>
                <h1 class="ey-dashboard-h1">Tableau de bord exécutif RH</h1>
                <p class="ey-dashboard-subtitle">Analyses Stratégiques RH & Planification des Effectifs</p>
            </div>
        </div>
        <div class="ey-dashboard-actions">
            <button class="ey-btn-analytics ey-btn-secondary" onclick="window.print()">
                <i class="fas fa-print"></i> Export PDF
            </button>
            <button class="ey-btn-analytics ey-btn-primary" onclick="refreshData()">
                <i class="fas fa-sync-alt"></i> Actualiser
            </button>
        </div>
    </div>

    <!-- Power BI-like Filters Bar -->
    <div class="ey-filters-bar">
        <div class="ey-filters-header">
            <div class="ey-filters-title">
                <i class="fas fa-filter"></i>
                <span>Filtres</span>
            </div>
            <button class="ey-filters-reset" onclick="resetFilters()">
                <i class="fas fa-undo"></i> Réinitialiser
            </button>
        </div>
        <div class="ey-filters-content">
            <!-- Search Bar -->
            <div class="ey-filter-group">
                <label class="ey-filter-label">Recherche</label>
                <div class="ey-search-wrapper">
                    <i class="fas fa-search"></i>
                    <input type="text" class="ey-search-input" id="searchFilter" placeholder="Rechercher collaborateur, compétence..." onkeyup="applyFilters()">
                </div>
            </div>

            <!-- Department Filter -->
            <div class="ey-filter-group">
                <label class="ey-filter-label">Département</label>
                <select class="ey-filter-select" id="departmentFilter" onchange="applyFilters()">
                    <option value="">Tous les départements</option>
                    <option value="IT">IT</option>
                    <option value="Finance">Finance</option>
                    <option value="RH">RH</option>
                    <option value="Marketing">Marketing</option>
                    <option value="Operations">Opérations</option>
                    <option value="Sales">Ventes</option>
                </select>
            </div>

            <!-- Grade Filter -->
            <div class="ey-filter-group">
                <label class="ey-filter-label">Grade</label>
                <select class="ey-filter-select" id="gradeFilter" onchange="applyFilters()">
                    <option value="">Tous les grades</option>
                    <option value="A">Grade A</option>
                    <option value="B">Grade B</option>
                    <option value="C">Grade C</option>
                    <option value="D">Grade D</option>
                    <option value="E">Grade E</option>
                </select>
            </div>

            <!-- Competency Filter -->
            <div class="ey-filter-group">
                <label class="ey-filter-label">Compétence</label>
                <select class="ey-filter-select" id="competencyFilter" onchange="applyFilters()">
                    <option value="">Toutes les compétences</option>
                    <option value="Leadership">Leadership</option>
                    <option value="Communication">Communication</option>
                    <option value="Technical">Technique</option>
                    <option value="Project Management">Gestion de projet</option>
                    <option value="Analytics">Analytique</option>
                </select>
            </div>

            <!-- Time Range Filter -->
            <div class="ey-filter-group">
                <label class="ey-filter-label">Période</label>
                <select class="ey-filter-select" id="timeRangeFilter" onchange="applyFilters()">
                    <option value="6m">6 derniers mois</option>
                    <option value="1y">1 an</option>
                    <option value="2y">2 ans</option>
                    <option value="all">Tout l'historique</option>
                </select>
            </div>

            <!-- Active Filters Display -->
            <div class="ey-active-filters" id="activeFilters"></div>
        </div>
    </div>

    <!-- Sticky KPI Cards Row -->
    <div class="ey-kpi-wrapper">
        <div class="ey-kpi-grid">
        <!-- KPI 1 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-blue">
                    <i class="fas fa-users"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-up">
                    <i class="fas fa-arrow-up"></i> +12%
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.CollaborateursActifs</div>
            <div class="ey-kpi-label">Collaborateurs Actifs</div>
            <div class="ey-kpi-sub">@ViewBag.CollaborateursActifs total</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-up" style="width: 85%"></div>
            </div>
        </div>

        <!-- KPI 2 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-green">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-up">
                    <i class="fas fa-arrow-up"></i> +5%
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.TauxCompetencesValidees%</div>
            <div class="ey-kpi-label">Compétences Validées</div>
            <div class="ey-kpi-sub">@ViewBag.TotalCompetences compétences trackées</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-up" style="width: @ViewBag.TauxCompetencesValidees%"></div>
            </div>
        </div>

        <!-- KPI 3 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-yellow">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-stable">
                    <i class="fas fa-minus"></i> stable
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.TauxFormations%</div>
            <div class="ey-kpi-label">Progression Formations</div>
            <div class="ey-kpi-sub">@ViewBag.TotalInscriptions inscriptions</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-stable" style="width: @ViewBag.TauxFormations%"></div>
            </div>
        </div>

        <!-- KPI 4 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-red">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-down">
                    <i class="fas fa-arrow-down"></i> -2
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.PostesCritiques</div>
            <div class="ey-kpi-label">Postes Critiques</div>
            <div class="ey-kpi-sub">@ViewBag.RemplacantsDisponibles remplaçants potentiels</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-down" style="width: 30%"></div>
            </div>
        </div>

        <!-- KPI 5 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-purple">
                    <i class="fas fa-user-friends"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-up">
                    <i class="fas fa-arrow-up"></i> +3
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.RemplacantsDisponibles</div>
            <div class="ey-kpi-label">Remplaçants Disponibles</div>
            <div class="ey-kpi-sub">Seniors prêts pour succession</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-up" style="width: 65%"></div>
            </div>
        </div>

        <!-- KPI 6 -->
        <div class="ey-kpi-card">
            <div class="ey-kpi-header">
                <div class="ey-kpi-icon ey-kpi-orange">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div class="ey-kpi-trend ey-trend-down">
                    <i class="fas fa-arrow-down"></i> -8%
                </div>
            </div>
            <div class="ey-kpi-value">@ViewBag.TauxEcartsCritiques%</div>
            <div class="ey-kpi-label">Écarts Critiques</div>
            <div class="ey-kpi-sub">Skill gaps à combler</div>
            <div class="ey-kpi-progress">
                <div class="ey-kpi-progress-bar trend-down" style="width: @ViewBag.TauxEcartsCritiques%"></div>
            </div>
        </div>
        </div>
    </div>

    <!-- Section: Strategic Analytics -->
    <div class="ey-executive-section">
        <div class="ey-section-header" onclick="toggleSection('strategic-analytics')">
            <div class="ey-section-title">
                <i class="fas fa-chart-line"></i>
                <h2>Analyse Stratégique</h2>
                <span class="ey-section-badge">2 graphiques</span>
            </div>
            <button class="ey-collapse-btn" id="btn-strategic-analytics">
                <i class="fas fa-chevron-up"></i>
            </button>
        </div>
        <div class="ey-section-content" id="strategic-analytics">
            <!-- Charts Row 1 -->
            <div class="ey-charts-row">
        <!-- Chart: Evolution Skill Gaps -->
        <div class="ey-chart-card ey-chart-large">
            <div class="ey-chart-header">
                <h3 class="ey-chart-title">
                    <i class="fas fa-chart-line"></i>
                    Évolution des Écarts de Compétences
                </h3>
                <div class="ey-chart-filters">
                    <button class="ey-filter-btn active">6 mois</button>
                    <button class="ey-filter-btn">1 an</button>
                </div>
            </div>
            <div class="ey-chart-body">
                <canvas id="skillGapChart"></canvas>
            </div>
        </div>

        <!-- Chart: Progression Formations -->
        <div class="ey-chart-card ey-chart-medium">
            <div class="ey-chart-header">
                <h3 class="ey-chart-title">
                    <i class="fas fa-graduation-cap"></i>
                    Progression Formations
                </h3>
            </div>
            <div class="ey-chart-body">
                <canvas id="formationChart"></canvas>
            </div>
        </div>
        </div>
        </div>
    </div>

    <!-- Section: Departmental Analytics -->
    <div class="ey-executive-section">
        <div class="ey-section-header" onclick="toggleSection('departmental-analytics')">
            <div class="ey-section-title">
                <i class="fas fa-building"></i>
                <h2>Analyse Départementale</h2>
                <span class="ey-section-badge">3 graphiques</span>
            </div>
            <button class="ey-collapse-btn" id="btn-departmental-analytics">
                <i class="fas fa-chevron-up"></i>
            </button>
        </div>
        <div class="ey-section-content" id="departmental-analytics">
            <!-- Charts Row 2 -->
            <div class="ey-charts-row">
        <!-- Chart: Top Compétences Manquantes -->
        <div class="ey-chart-card ey-chart-medium">
            <div class="ey-chart-header">
                <h3 class="ey-chart-title">
                    <i class="fas fa-exclamation-circle"></i>
                    Top 5 Compétences à Développer
                </h3>
            </div>
            <div class="ey-chart-body">
                <canvas id="topCompetencesChart"></canvas>
            </div>
        </div>

        <!-- Chart: Répartition par Département -->
        <div class="ey-chart-card ey-chart-medium">
            <div class="ey-chart-header">
                <h3 class="ey-chart-title">
                    <i class="fas fa-building"></i>
                    Répartition par Département
                </h3>
            </div>
            <div class="ey-chart-body">
                <canvas id="deptChart"></canvas>
            </div>
        </div>

        <!-- Chart: Progression Mensuelle -->
        <div class="ey-chart-card ey-chart-small">
            <div class="ey-chart-header">
                <h3 class="ey-chart-title">
                    <i class="fas fa-users"></i>
                    Croissance RH
                </h3>
            </div>
            <div class="ey-chart-body">
                <canvas id="croissanceChart"></canvas>
            </div>
        </div>
        </div>
        </div>
    </div>

    <!-- Section: Skills Matrix -->
    <div class="ey-executive-section">
        <div class="ey-section-header" onclick="toggleSection('skills-matrix')">
            <div class="ey-section-title">
                <i class="fas fa-th"></i>
                <h2>Matrice de Compétences</h2>
                <span class="ey-section-badge">Heatmap Power BI</span>
            </div>
            <button class="ey-collapse-btn" id="btn-skills-matrix">
                <i class="fas fa-chevron-up"></i>
            </button>
        </div>
        <div class="ey-section-content" id="skills-matrix">
            <!-- Heatmap Section -->
            <div class="ey-heatmap-section">
        <div class="ey-heatmap-header">
            <h2 class="ey-heatmap-title">
                <i class="fas fa-th"></i>
                Matrice de Compétences - Heatmap Power BI
            </h2>
            <div class="ey-heatmap-legend">
                <div class="ey-legend-item">
                    <div class="ey-legend-color ey-level-high"></div>
                    <span>Niveau élevé (4-5)</span>
                </div>
                <div class="ey-legend-item">
                    <div class="ey-legend-color ey-level-medium"></div>
                    <span>Niveau moyen (3)</span>
                </div>
                <div class="ey-legend-item">
                    <div class="ey-legend-color ey-level-low"></div>
                    <span>Niveau faible (1-2)</span>
                </div>
                <div class="ey-legend-item">
                    <div class="ey-legend-color ey-level-critical"></div>
                    <span>Critique (0-1)</span>
                </div>
                <div class="ey-legend-item">
                    <div class="ey-legend-color ey-level-missing"></div>
                    <span>Non évalué</span>
                </div>
            </div>
        </div>
        
        <div class="ey-heatmap-container">
            <div class="ey-heatmap-wrapper">
                <table class="ey-heatmap-table">
                    <thead>
                        <tr>
                            <th class="ey-heatmap-corner">Collaborateur</th>
                            @foreach (var comp in heatmapCompetences)
                            {
                                <th class="ey-heatmap-col-header" title="@comp">@comp</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var collab in heatmapCollaborateurs)
                        {
                            <tr>
                                <td class="ey-heatmap-row-header">
                                    <div class="ey-collab-cell">
                                        <div class="ey-collab-avatar">@(collab.Prenom?[0])@(collab.Nom?[0])</div>
                                        <div class="ey-collab-info">
                                            <div class="ey-collab-name">@collab.Prenom @collab.Nom</div>
                                            <div class="ey-collab-dept">@collab.Departement</div>
                                        </div>
                                    </div>
                                </td>
                                @foreach (var compName in heatmapCompetences)
                                {
                                    var competence = collab.Competences != null ? collab.Competences.FirstOrDefault(c => c.Nom == compName) : null;
                                    var niveau = competence != null ? competence.NiveauActuel : 0;
                                    string classe;
                                    bool isCritical = false;
                                    if (niveau >= 4) { classe = "ey-level-high"; }
                                    else if (niveau == 3) { classe = "ey-level-medium"; }
                                    else if (niveau >= 1) { classe = "ey-level-low"; }
                                    else if (niveau == 0) { classe = "ey-level-critical"; isCritical = true; }
                                    else { classe = "ey-level-missing"; }
                                    <td class="ey-heatmap-cell @classe" data-niveau="@niveau" data-collab="@collab.Prenom @collab.Nom" data-competence="@compName" data-dept="@collab.Departement">
                                        @(niveau > 0 ? niveau.ToString() : "-")
                                        @if (isCritical)
                                        {
                                            <span class="ey-critical-badge">!</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Chart 1: Evolution Skill Gaps
        const skillGapCtx = document.getElementById('skillGapChart').getContext('2d');
        new Chart(skillGapCtx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin'],
                datasets: [{
                    label: 'Écarts critiques',
                    data: @Html.Raw(Json.Serialize(ViewBag.EvolutionSkillGaps)),
                    borderColor: '#ffe600',
                    backgroundColor: 'rgba(255, 230, 0, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#ffe600',
                    pointBorderColor: '#1a1a1a',
                    pointBorderWidth: 2,
                    pointRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { family: 'Inter' } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Inter' } }
                    }
                }
            }
        });

        // Chart 2: Progression Formations (Doughnut)
        const formationCtx = document.getElementById('formationChart').getContext('2d');
        new Chart(formationCtx, {
            type: 'doughnut',
            data: {
                labels: ['Terminées', 'En cours', 'Non démarrées'],
                datasets: [{
                    data: [@ViewBag.TotalInscriptions, 12, 8],
                    backgroundColor: ['#ffe600', '#1a1a1a', '#e0e0e0'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { usePointStyle: true, padding: 20 }
                    }
                }
            }
        });

        // Chart 3: Top Compétences Manquantes (Bar)
        const topCompCtx = document.getElementById('topCompetencesChart').getContext('2d');
        const topCompData = @Html.Raw(Json.Serialize(ViewBag.TopCompetencesManquantes));
        new Chart(topCompCtx, {
            type: 'bar',
            data: {
                labels: topCompData.map(x => x.nom),
                datasets: [{
                    label: 'Collaborateurs (niveau < 3)',
                    data: topCompData.map(x => x.count),
                    backgroundColor: '#1a1a1a',
                    hoverBackgroundColor: '#ffe600',
                    borderRadius: 6,
                    barThickness: 30
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: 'rgba(0,0,0,0.05)' } },
                    y: { grid: { display: false } }
                }
            }
        });

        // Chart 4: Répartition par Département (Polar Area)
        const deptCtx = document.getElementById('deptChart').getContext('2d');
        const deptData = @Html.Raw(Json.Serialize(ViewBag.RepartitionParDepartement));
        new Chart(deptCtx, {
            type: 'polarArea',
            data: {
                labels: deptData.map(x => x.departement),
                datasets: [{
                    label: 'Moyenne des compétences',
                    data: deptData.map(x => x.averageScore),
                    backgroundColor: [
                        'rgba(255, 230, 0, 0.8)',
                        'rgba(26, 26, 26, 0.8)',
                        'rgba(108, 117, 125, 0.8)',
                        'rgba(255, 193, 7, 0.8)',
                        'rgba(220, 53, 69, 0.8)',
                        'rgba(40, 167, 69, 0.8)'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: { boxWidth: 15, padding: 15 }
                    }
                },
                scales: {
                    r: {
                        ticks: { display: false },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    }
                }
            }
        });

        // Chart 5: Progression Mensuelle (Line Area)
        const croissanceCtx = document.getElementById('croissanceChart').getContext('2d');
        new Chart(croissanceCtx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin'],
                datasets: [{
                    label: 'Collaborateurs',
                    data: @Html.Raw(Json.Serialize(ViewBag.ProgressionMensuelle)),
                    borderColor: '#1a1a1a',
                    backgroundColor: 'rgba(26, 26, 26, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#ffe600'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { display: false },
                    x: { grid: { display: false } }
                }
            }
        });

        function refreshData() {
            location.reload();
        }

        // Collapsible Sections Functionality
        function toggleSection(sectionId) {
            const content = document.getElementById(sectionId);
            const btn = document.getElementById('btn-' + sectionId);
            const icon = btn.querySelector('i');

            if (content.classList.contains('collapsed')) {
                content.classList.remove('collapsed');
                icon.classList.remove('fa-chevron-down');
                icon.classList.add('fa-chevron-up');
            } else {
                content.classList.add('collapsed');
                icon.classList.remove('fa-chevron-up');
                icon.classList.add('fa-chevron-down');
            }
        }

        // ========================================
        // FILTERS FUNCTIONALITY
        // ========================================
        let currentFilters = {
            search: '',
            department: '',
            grade: '',
            competency: '',
            timeRange: '6m'
        };

        function applyFilters() {
            currentFilters.search = document.getElementById('searchFilter').value.toLowerCase();
            currentFilters.department = document.getElementById('departmentFilter').value;
            currentFilters.grade = document.getElementById('gradeFilter').value;
            currentFilters.competency = document.getElementById('competencyFilter').value;
            currentFilters.timeRange = document.getElementById('timeRangeFilter').value;

            updateActiveFilters();
            filterHeatmap();
            filterCharts();
        }

        function resetFilters() {
            document.getElementById('searchFilter').value = '';
            document.getElementById('departmentFilter').value = '';
            document.getElementById('gradeFilter').value = '';
            document.getElementById('competencyFilter').value = '';
            document.getElementById('timeRangeFilter').value = '6m';

            currentFilters = {
                search: '',
                department: '',
                grade: '',
                competency: '',
                timeRange: '6m'
            };

            updateActiveFilters();
            filterHeatmap();
            filterCharts();
        }

        function updateActiveFilters() {
            const container = document.getElementById('activeFilters');
            container.innerHTML = '';

            if (currentFilters.search) {
                addFilterTag(container, 'Recherche: ' + currentFilters.search, 'search');
            }
            if (currentFilters.department) {
                addFilterTag(container, 'Département: ' + currentFilters.department, 'department');
            }
            if (currentFilters.grade) {
                addFilterTag(container, 'Grade: ' + currentFilters.grade, 'grade');
            }
            if (currentFilters.competency) {
                addFilterTag(container, 'Compétence: ' + currentFilters.competency, 'competency');
            }
            if (currentFilters.timeRange && currentFilters.timeRange !== '6m') {
                const timeLabels = { '1y': '1 an', '2y': '2 ans', 'all': 'Tout' };
                addFilterTag(container, 'Période: ' + timeLabels[currentFilters.timeRange], 'timeRange');
            }
        }

        function addFilterTag(container, label, filterType) {
            const tag = document.createElement('div');
            tag.className = 'ey-filter-tag';
            tag.innerHTML = `
                <span>${label}</span>
                <span class="ey-filter-tag-remove" onclick="removeFilter('${filterType}')">×</span>
            `;
            container.appendChild(tag);
        }

        function removeFilter(filterType) {
            switch(filterType) {
                case 'search':
                    document.getElementById('searchFilter').value = '';
                    currentFilters.search = '';
                    break;
                case 'department':
                    document.getElementById('departmentFilter').value = '';
                    currentFilters.department = '';
                    break;
                case 'grade':
                    document.getElementById('gradeFilter').value = '';
                    currentFilters.grade = '';
                    break;
                case 'competency':
                    document.getElementById('competencyFilter').value = '';
                    currentFilters.competency = '';
                    break;
                case 'timeRange':
                    document.getElementById('timeRangeFilter').value = '6m';
                    currentFilters.timeRange = '6m';
                    break;
            }
            updateActiveFilters();
            filterHeatmap();
            filterCharts();
        }

        function filterHeatmap() {
            const rows = document.querySelectorAll('.ey-heatmap-table tbody tr');
            rows.forEach(row => {
                const collabCell = row.querySelector('.ey-collab-cell');
                if (!collabCell) return;

                const collabName = collabCell.querySelector('.ey-collab-name')?.textContent.toLowerCase() || '';
                const collabDept = collabCell.querySelector('.ey-collab-dept')?.textContent.toLowerCase() || '';

                let visible = true;

                if (currentFilters.search && !collabName.includes(currentFilters.search)) {
                    visible = false;
                }
                if (currentFilters.department && !collabDept.includes(currentFilters.department.toLowerCase())) {
                    visible = false;
                }

                row.style.display = visible ? '' : 'none';
            });
        }

        function filterCharts() {
            // Filter heatmap competency columns based on competency filter
            if (currentFilters.competency) {
                const headers = document.querySelectorAll('.ey-heatmap-col-header');
                const table = document.querySelector('.ey-heatmap-table');
                if (!table) return;

                const allHeaders = Array.from(headers);
                const competencyIndex = allHeaders.findIndex(h => h.textContent.includes(currentFilters.competency));

                if (competencyIndex === -1) return;

                // Hide all columns except the selected competency
                allHeaders.forEach((header, index) => {
                    const isVisible = index === competencyIndex;
                    header.style.display = isVisible ? '' : 'none';

                    // Hide corresponding cells in each row
                    const rows = table.querySelectorAll('tbody tr');
                    rows.forEach(row => {
                        const cells = row.querySelectorAll('td');
                        if (cells[index + 1]) { // +1 because first column is the collaborator name
                            cells[index + 1].style.display = isVisible ? '' : 'none';
                        }
                    });
                });
            } else {
                // Show all columns
                const headers = document.querySelectorAll('.ey-heatmap-col-header');
                const table = document.querySelector('.ey-heatmap-table');
                if (!table) return;

                headers.forEach(header => {
                    header.style.display = '';
                });

                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    cells.forEach(cell => {
                        cell.style.display = '';
                    });
                });
            }
        }

        // Initialize filters on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateActiveFilters();
            initHeatmapTooltips();
            animateCounters();
            initChartAnimations();
        });

        // ========================================
        // COUNTER ANIMATIONS
        // ========================================
        function animateCounters() {
            const counters = document.querySelectorAll('.ey-kpi-value');
            counters.forEach(counter => {
                const text = counter.textContent;
                const hasPercent = text.includes('%');
                const value = parseFloat(text.replace('%', ''));
                const duration = 1500;
                const steps = 60;
                const increment = value / steps;
                let current = 0;
                let step = 0;

                const timer = setInterval(() => {
                    step++;
                    current += increment;
                    if (step >= steps) {
                        counter.textContent = hasPercent ? value + '%' : Math.round(value);
                        clearInterval(timer);
                    } else {
                        counter.textContent = hasPercent ? Math.round(current) + '%' : Math.round(current);
                    }
                }, duration / steps);
            });
        }

        // ========================================
        // CHART REVEAL ANIMATIONS
        // ========================================
        function initChartAnimations() {
            const chartCanvases = document.querySelectorAll('canvas');
            chartCanvases.forEach(canvas => {
                canvas.style.opacity = '0';
                canvas.style.transform = 'scale(0.95)';
                canvas.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
                
                setTimeout(() => {
                    canvas.style.opacity = '1';
                    canvas.style.transform = 'scale(1)';
                }, 800);
            });
        }

        // ========================================
        // HEATMAP TOOLTIPS & INSIGHTS
        // ========================================
        function initHeatmapTooltips() {
            const tooltip = document.createElement('div');
            tooltip.className = 'ey-heatmap-tooltip';
            document.body.appendChild(tooltip);

            const cells = document.querySelectorAll('.ey-heatmap-cell');
            cells.forEach(cell => {
                cell.addEventListener('mouseenter', showTooltip);
                cell.addEventListener('mouseleave', hideTooltip);
                cell.addEventListener('mousemove', moveTooltip);
            });
        }

        function showTooltip(e) {
            const cell = e.target.closest('.ey-heatmap-cell');
            if (!cell) return;

            const tooltip = document.querySelector('.ey-heatmap-tooltip');
            const niveau = parseInt(cell.dataset.niveau);
            const collab = cell.dataset.collab;
            const competence = cell.dataset.competence;
            const dept = cell.dataset.dept;

            let levelText, levelColor, insight;

            if (niveau >= 4) {
                levelText = 'Élevé';
                levelColor = '#16a34a';
                insight = 'Excellente maîtrise - Peut former d autres';
            } else if (niveau === 3) {
                levelText = 'Moyen';
                levelColor = '#f59e0b';
                insight = 'Niveau satisfaisant - Formation recommandée';
            } else if (niveau >= 1) {
                levelText = 'Faible';
                levelColor = '#dc2626';
                insight = 'Besoin de formation immédiat';
            } else if (niveau === 0) {
                levelText = 'Critique';
                levelColor = '#991b1b';
                insight = 'Compétence manquante - Recrutement ou formation prioritaire';
            } else {
                levelText = 'Non évalué';
                levelColor = '#6c757d';
                insight = 'Évaluation requise';
            }

            tooltip.innerHTML = `
                <div class="ey-tooltip-header">${competence}</div>
                <div class="ey-tooltip-row">
                    <span class="ey-tooltip-label">Collaborateur:</span>
                    <span class="ey-tooltip-value">${collab}</span>
                </div>
                <div class="ey-tooltip-row">
                    <span class="ey-tooltip-label">Département:</span>
                    <span class="ey-tooltip-value">${dept}</span>
                </div>
                <div class="ey-tooltip-row">
                    <span class="ey-tooltip-label">Niveau:</span>
                    <span class="ey-tooltip-value" style="color: ${levelColor}">${levelText} (${niveau}/5)</span>
                </div>
                <div class="ey-tooltip-insight">${insight}</div>
            `;

            tooltip.classList.add('visible');
        }

        function hideTooltip() {
            const tooltip = document.querySelector('.ey-heatmap-tooltip');
            if (tooltip) {
                tooltip.classList.remove('visible');
            }
        }

        function moveTooltip(e) {
            const tooltip = document.querySelector('.ey-heatmap-tooltip');
            if (!tooltip) return;

            const xOffset = 15;
            const yOffset = 15;
            const tooltipRect = tooltip.getBoundingClientRect();
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;

            let left = e.clientX + xOffset;
            let top = e.clientY + yOffset;

            // Prevent tooltip from going off screen
            if (left + tooltipRect.width > windowWidth) {
                left = e.clientX - tooltipRect.width - xOffset;
            }
            if (top + tooltipRect.height > windowHeight) {
                top = e.clientY - tooltipRect.height - yOffset;
            }

            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';
        }
    </script>
}
