@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var role = roles.FirstOrDefault() ?? "Utilisateur";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIRH EY</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ey-modern-overrides.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ey-sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }
    <div class="ey-app">
        <aside class="ey-sidebar">
            <div class="ey-sidebar-content">
                <div class="ey-logo-wrap">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <img src="~/images/ey-logo.png" alt="EY" class="ey-brand-logo" />
                        <div class="ey-logo-main">SIRH EY</div>
                    </div>
                    <div class="ey-logo-sub">Bâtir un monde du travail plus performant</div>
                </div>

                <!-- Quick Access / Favorites -->
                <div class="ey-quick-access">
                    <div class="ey-section-title">
                        <i class="fas fa-star"></i>
                        <span>Accès rapide</span>
                    </div>
                    <nav class="nav flex-column ey-nav">
                        <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-th-large"></i><span class="nav-link-label">Dashboard</span>
                        </a>
                        <a class="nav-link @(currentController == "Reporting" ? "active" : "")" asp-controller="Reporting" asp-action="ExecutiveDashboard">
                            <i class="fas fa-chart-line"></i><span class="nav-link-label">Tableau de bord exécutif</span>
                        </a>
                    </nav>
                </div>

                <!-- Main Navigation -->
                <nav class="nav flex-column ey-nav">
                    <!-- Core RH -->
                    <div class="ey-menu-item">
                        <div class="ey-menu-header" onclick="toggleSubmenu('core-rh')">
                            <div class="ey-menu-title">
                                <i class="fas fa-users-cog"></i>
                                <span>Core RH</span>
                            </div>
                            <i class="fas fa-chevron-down ey-chevron" id="chevron-core-rh"></i>
                        </div>
                        <ul class="ey-submenu" id="submenu-core-rh">
                            <li>
                                <a class="nav-link @((currentController == "Collaborateurs" && currentAction == "Index") ? "active" : "")" asp-controller="Collaborateurs" asp-action="Index">
                                    <i class="fas fa-users"></i><span class="nav-link-label">Collaborateurs</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @((currentController == "Collaborateurs" && currentAction == "Details") ? "active" : "")" asp-controller="Collaborateurs" asp-action="Details" asp-route-id="1">
                                    <i class="fas fa-id-card"></i><span class="nav-link-label">Compétences & Formations</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Formations -->
                    <div class="ey-menu-item">
                        <div class="ey-menu-header" onclick="toggleSubmenu('formations')">
                            <div class="ey-menu-title">
                                <i class="fas fa-graduation-cap"></i>
                                <span>Formations</span>
                                <span class="ey-badge ey-badge-warning">3</span>
                            </div>
                            <i class="fas fa-chevron-down ey-chevron" id="chevron-formations"></i>
                        </div>
                        <ul class="ey-submenu" id="submenu-formations">
                            <li>
                                <a class="nav-link @(currentController == "Formations" ? "active" : "")" asp-controller="Formations" asp-action="Index">
                                    <i class="fas fa-book"></i><span class="nav-link-label">Catalogue</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" asp-controller="Formations" asp-action="Index">
                                    <i class="fas fa-tasks"></i><span class="nav-link-label">Parcours en cours / Suivi</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" asp-controller="Formations" asp-action="Index">
                                    <i class="fas fa-certificate"></i><span class="nav-link-label">Certifications</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Compétences -->
                    <div class="ey-menu-item">
                        <div class="ey-menu-header" onclick="toggleSubmenu('competences')">
                            <div class="ey-menu-title">
                                <i class="fas fa-chart-bar"></i>
                                <span>Compétences</span>
                            </div>
                            <i class="fas fa-chevron-down ey-chevron" id="chevron-competences"></i>
                        </div>
                        <ul class="ey-submenu" id="submenu-competences">
                            <li>
                                <a class="nav-link @(currentController == "Competences" && currentAction == "MatriceEquipe" ? "active" : "")" asp-controller="Competences" asp-action="MatriceEquipe">
                                    <i class="fas fa-th"></i><span class="nav-link-label">Matrice de compétences</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(currentController == "Talent" ? "active" : "")" asp-controller="Talent" asp-action="Index">
                                    <i class="fas fa-gem"></i><span class="nav-link-label">Gestion des talents</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" asp-controller="Talent" asp-action="Index">
                                    <i class="fas fa-border-all"></i><span class="nav-link-label">Matrice 9-box</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Analytique & Reporting -->
                    <div class="ey-menu-item">
                        <div class="ey-menu-header" onclick="toggleSubmenu('analytics')">
                            <div class="ey-menu-title">
                                <i class="fas fa-chart-pie"></i>
                                <span>Analytique & Reporting</span>
                            </div>
                            <i class="fas fa-chevron-down ey-chevron" id="chevron-analytics"></i>
                        </div>
                        <ul class="ey-submenu" id="submenu-analytics">
                            <li>
                                <a class="nav-link" asp-controller="RHInsights" asp-action="Index">
                                    <i class="fas fa-brain"></i><span class="nav-link-label">RH Insights</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" asp-controller="Reporting" asp-action="Index">
                                    <i class="fas fa-chart-area"></i><span class="nav-link-label">Graphiques de performance</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Chatbot IA -->
                    <div class="ey-menu-item">
                        <div class="ey-menu-header"">
                            @* <div class="ey-menu-title">
                                <i class="fas fa-robot"></i>
                                <span>Chatbot IA</span>
                                <span class="ey-badge ey-badge-info">Bientôt</span>
                            </div> *@
                            @* <i class="fas fa-chevron-down ey-chevron" id="chevron-chatbot"></i> *@
                        </div>
                        @* <ul class="ey-submenu" id="submenu-chatbot">
                            <li>
                                <a class="nav-link" href="javascript:void(0)" onclick="toggleChatbot()">
                                    <i class="fas fa-comment-dots"></i><span class="nav-link-label">Assistant IA</span>
                                </a>
                            </li>
                        </ul> *@
                    </div>
                </nav>
            </div>

            <div class="ey-sidebar-footer">
                <a class="nav-link @(currentController == "Home" && currentAction == "Settings" ? "active" : "")" asp-controller="Home" asp-action="Settings">
                    <i class="fas fa-cog"></i><span class="nav-link-label">Paramètres</span>
                </a>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="logoutForm" class="d-inline">
                    <a class="nav-link" href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();">
                        <i class="fas fa-sign-out-alt"></i><span class="nav-link-label">Déconnexion</span>
                    </a>
                </form>
            </div>
        </aside>

        <div class="ey-main">
            <div class="ey-topbar">
                <div class="ey-topbar-brand fw-semibold text-dark">Portail RH EY</div>
                <div class="ey-search flex-grow-1 mx-3">
                    <input class="form-control form-control-sm ey-search-input" placeholder="Rechercher un collaborateur, une formation, une compétence..." />
                </div>
                <div class="d-flex align-items-center gap-3 ey-topbar-actions">
                    <span class="ey-icon-btn position-relative"><i class="far fa-bell"></i><span class="ey-dot-alert"></span></span>
                    <span class="ey-icon-btn"><i class="far fa-question-circle"></i></span>
                    <span class="ey-icon-btn"><i class="fas fa-cog"></i></span>
                    <div class="text-end lh-sm d-none d-md-block">
                        <div class="fw-semibold small mb-0">@User.Identity.Name</div>
                        <div class="text-muted" style="font-size:10px;letter-spacing:.04em;">@role.ToUpper()</div>
                    </div>
                    <div class="ey-user-avatar">@(User.Identity.Name != null ? User.Identity.Name.Substring(0, 2).ToUpper() : "U")</div>
                </div>
            </div>

            <main class="ey-content">
                @RenderBody()
            </main>
        </div>
    </div>
   
    <partial name="_ChatbotWidget" />


    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/ey-sidebar.js" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>