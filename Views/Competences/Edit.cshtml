            </div>
            <div class="form-group">
                <label asp-for="NiveauActuel" class="control-label"></label>
                <input asp-for="NiveauActuel" class="form-control" />
                <span asp-validation-for="NiveauActuel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DateEvaluation" class="control-label"></label>
                <input asp-for="DateEvaluation" class="form-control" />
                <span asp-validation-for="DateEvaluation" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CollaborateurId" class="control-label"></label>
                <select asp-for="CollaborateurId" class="form-control" asp-items="ViewBag.CollaborateurId"></select>
                <span asp-validation-for="CollaborateurId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
