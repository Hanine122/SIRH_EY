@model IEnumerable<SIRH.EY.Models.Competence>

@{
    ViewData["Title"] = "Compétences";
    var collaborateurNom = ViewBag.CollaborateurNom;
    var grade = ViewBag.GradeCollaborateur as string;
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var categorieCourante = ViewBag.CategorieCourante as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3">Compétences de @collaborateurNom</h1>
        <p class="text-muted">Grade actuel : <strong>@(grade ?? "Non défini")</strong></p>
    </div>
    <div>
        <a asp-action="Create" asp-route-collaborateurId="@ViewBag.CollaborateurId" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle compétence
        </a>
    </div>
</div>

<div class="ey-form-shell p-3 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
        <div class="small fw-semibold text-muted">Filtrer et explorer</div>
        <div class="small text-muted">@Model.Count() compétence(s)</div>
    </div>
    <div class="card-body p-0">
        <form method="get" class="row g-3">
            <input type="hidden" name="collaborateurId" value="@ViewBag.CollaborateurId" />
            <div class="col-md-8">
                <label class="form-label">Filtrer par catégorie</label>
                <select name="categorie" class="form-select ey-select">
                    <option value="">Toutes les catégories</option>
                    @foreach (var cat in categories)
                    {
                        if (cat == categorieCourante)
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="ey-btn-main w-100">Filtrer</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var comp in Model)
    {
        var seuilRequis = SIRH.EY.Services.CompetenceRules.GetSeuilRequis(grade ?? "Junior");
        bool sousSeuil = comp.NiveauActuel < seuilRequis;
        var evaluation = comp.EvaluationCompetence;
        var seuilRhPourcent = evaluation?.SeuilRh ?? (comp.NiveauCible * 20);
        var autoEvalPourcent = evaluation?.AutoEvaluationCollaborateur;
        var managerPourcent = evaluation?.EvaluationManager;
        var gap = comp.NiveauCible - comp.NiveauActuel;
        
        string rhBadgeClass = "bg-secondary";
        string rhBadgeText = "En attente";
        if (managerPourcent.HasValue) {
            if (comp.NiveauActuel >= comp.NiveauCible) { rhBadgeClass = "bg-success"; rhBadgeText = "Conforme"; }
            else if (gap == 1) { rhBadgeClass = "bg-warning text-dark"; rhBadgeText = "Progression"; }
            else { rhBadgeClass = "bg-danger"; rhBadgeText = "Critique"; }
        }
        if (sousSeuil) { rhBadgeClass = "bg-danger"; rhBadgeText = "Niveau insuffisant"; }

        <div class="col-md-6 col-xl-4">
            <div class="ey-card ey-competence-card p-4 h-100 position-relative ey-card-hover border-0 shadow-sm bg-white" style="border-radius: 12px; transition: all 0.3s ease;">
                <!-- Overlay highlight -->
                <div class="position-absolute top-0 start-0 w-100 bg-warning" style="height: 4px; border-radius: 12px 12px 0 0;"></div>
                
                <div class="d-flex justify-content-between align-items-start mb-3 mt-1">
                    <div>
                        <h5 class="fw-bold mb-1 text-dark" style="letter-spacing: -0.5px;">@comp.Nom</h5>
                        <div class="d-flex gap-2">
                            <span class="badge border border-secondary text-secondary bg-transparent fw-normal" style="font-size: 0.7rem;">@(comp.CategorieCompetence?.Nom ?? "Hard Skill")</span>
                        </div>
                    </div>
                    <span class="badge @rhBadgeClass rounded-pill px-3 py-2 shadow-sm" style="font-size: 0.75rem;">@rhBadgeText</span>
                </div>

                <div class="mt-4">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span class="text-muted">Niveau Actuel</span>
                        <span class="text-dark">@comp.NiveauActuel / 5</span>
                    </div>
                    <div class="progress mb-3 rounded-pill" style="height: 8px;">
                        @{ string couleur = comp.NiveauActuel >= comp.NiveauCible ? "bg-success" : (gap <= 1 ? "bg-warning" : "bg-danger"); }
                        <div class="progress-bar @couleur" style="width: @((comp.NiveauActuel/5.0)*100)%"></div>
                    </div>
                    
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span class="text-muted">Niveau Cible</span>
                        <span class="text-dark">@comp.NiveauCible / 5</span>
                    </div>
                    <div class="progress rounded-pill mb-4" style="height: 6px;">
                        <div class="progress-bar bg-light border border-secondary" style="width: @((comp.NiveauCible/5.0)*100)%"></div>
                    </div>
                </div>

                <div class="ey-meta-panel p-3 bg-light rounded border border-light mt-auto">
                    <div class="small text-muted fw-bold mb-3 border-bottom pb-2 text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.5px;">Analytics RH</div>
                    
                    <div class="d-flex justify-content-between align-items-center small mb-2">
                        <span class="text-muted"><i class="fas fa-bullseye me-2 text-warning"></i>Objectif RH</span>
                        <strong class="text-dark">@seuilRhPourcent%</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small mb-2">
                        <span class="text-muted"><i class="fas fa-user-edit me-2 text-primary"></i>Auto-éval.</span>
                        <strong class="text-dark">@(autoEvalPourcent.HasValue ? $"{autoEvalPourcent.Value}%" : "—")</strong>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted"><i class="fas fa-check-double me-2 text-success"></i>Manager</span>
                        <strong>
                            @if (managerPourcent.HasValue) {
                                <span class="badge bg-success text-white rounded-pill px-2">@managerPourcent.Value%</span>
                            } else {
                                <span class="badge bg-secondary text-white rounded-pill px-2">En attente</span>
                            }
                        </strong>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a asp-action="AutoEvaluation" asp-route-id="@comp.Id" class="btn btn-outline-dark btn-sm flex-grow-1 rounded-pill fw-bold">
                        Auto-éval
                    </a>
                    <a asp-action="ValidationManager" asp-route-id="@comp.Id" class="ey-btn-main btn-sm flex-grow-1 text-center text-decoration-none rounded-pill py-1">
                        Manager
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<!-- Plan de développement -->
<div class="mt-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <form asp-action="GenererPlanDeveloppement" method="post" class="ms-auto">
            @Html.AntiForgeryToken()
            <input type="hidden" name="collaborateurId" value="@ViewBag.CollaborateurId" />
            <button type="submit" class="ey-btn-main">
                <i class="fas fa-wand-magic-sparkles"></i> Generer les recommandations
            </button>
        </form>
    </div>
    <h4>Plan de développement personnalisé</h4>
    @if (ViewBag.PlanDeveloppement != null && ((List<SIRH.EY.Models.PlanDeveloppement>)ViewBag.PlanDeveloppement).Any())
    {
        <div class="row">
            @foreach (var plan in ViewBag.PlanDeveloppement)
            {
                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-title">@plan.Formation?.Titre</h6>
                            <p class="card-text small">Statut : @plan.Statut</p>
                            @if (!string.IsNullOrWhiteSpace(plan.Commentaire))
                            {
                                <p class="card-text small text-muted">@plan.Commentaire</p>
                            }
                            <p class="card-text small">Recommandé le : @plan.DateRecommandation.ToString("dd/MM/yyyy")</p>
                            <button class="btn btn-sm btn-outline-primary" onclick="alert('Détails à venir')">Détails</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">Aucune formation recommandée pour le moment.</p>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-4">Aucune compétence trouvée pour ce collaborateur.</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-4"><i class="fas fa-check-circle me-1"></i> @TempData["Success"]</div>
}
<div class="mt-4 d-flex gap-2 flex-wrap">
    <a asp-action="MatriceEquipe" asp-route-collaborateurId="@ViewBag.CollaborateurId" class="ey-btn-ghost text-decoration-none">
        Matrice équipe
    </a>
    <a asp-controller="Collaborateurs" asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Retour au Core RH
    </a>
</div>
