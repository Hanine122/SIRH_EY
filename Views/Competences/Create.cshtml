@model SIRH.EY.Models.Competence

@{
    ViewData["Title"] = "Nouvelle competence";
    var grade = ViewBag.CollaborateurGrade as string ?? "";
    var competencesDisponibles = ViewBag.CompetencesDisponibles as IReadOnlyList<SIRH.EY.Models.CompetenceRequiseParPoste>
        ?? Array.Empty<SIRH.EY.Models.CompetenceRequiseParPoste>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/ey-forms-premium.css" asp-append-version="true" />
}

<div class="ey-premium-card">
    <!-- Header Premium -->
    <div class="ey-card-header-premium">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <div class="ey-header-icon">
                    <i class="fas fa-star"></i>
                </div>
                <h1 class="ey-header-title">Ajouter des compétences</h1>
                <p class="ey-header-subtitle">Référentiel RH EY - Sélectionnez les compétences selon le grade</p>
            </div>
            <a asp-action="Index" asp-route-collaborateurId="@ViewBag.CollaborateurId" class="ey-back-link">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <!-- Form Body -->
    <div class="ey-form-body">
        <form asp-action="Create" method="post" id="competenceCreateForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CollaborateurId" value="@ViewBag.CollaborateurId" />
            <input asp-for="Nom" type="hidden" id="Nom" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <span asp-validation-for="Nom" class="text-danger"></span>

            <!-- Section: Filtres et Configuration -->
            <div class="ey-form-section">
                <div class="ey-section-title">Configuration</div>
                <div class="ey-filter-bar">
                    <div class="ey-filter-grid">
                        <div>
                            <label class="ey-label">Grade</label>
                            <select class="ey-input" id="gradeSelect" name="selectedGrade">
                                <option value="">Sélectionnez un grade</option>
                                <option value="Junior" selected="@(grade == "Junior")">Junior</option>
                                <option value="Senior" selected="@(grade == "Senior")">Senior</option>
                                <option value="Manager" selected="@(grade == "Manager")">Manager</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="CategorieCompetenceId" class="ey-label">Catégorie</label>
                            <select asp-for="CategorieCompetenceId" class="ey-input" asp-items="ViewBag.Categories">
                                <option value="">Toutes les catégories</option>
                            </select>
                            <span asp-validation-for="CategorieCompetenceId" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="NiveauActuel" class="ey-label">Niveau actuel</label>
                            <input asp-for="NiveauActuel" class="ey-input" type="number" min="1" max="5" />
                            <span asp-validation-for="NiveauActuel" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="DateEvaluation" class="ey-label">Date d'évaluation</label>
                            <input asp-for="DateEvaluation" class="ey-input" type="date" />
                            <span asp-validation-for="DateEvaluation" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Compétences Disponibles -->
            <div class="ey-form-section">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="ey-section-title ey-mb-0">Compétences disponibles</div>
                    <div class="ey-counter" id="competenceCounter">
                        <span class="ey-counter-number" id="competenceCount">@competencesDisponibles.Count</span>
                        <span>compétence(s)</span>
                    </div>
                </div>

                <div class="ey-competence-grid" id="competenceCheckboxList">
                    @foreach (var item in competencesDisponibles)
                    {
                        <div class="ey-competence-card" onclick="toggleCompetence(this)">
                            <input class="competence-choice d-none" type="checkbox" name="selectedCompetences" value="@item.Competence" id="comp_@Math.Abs(item.Competence.GetHashCode())" autocomplete="off" />
                            <div class="ey-competence-title">@item.Competence</div>
                            <div class="ey-competence-meta">@item.Poste - Niveau requis @item.NiveauRequis/5</div>
                        </div>
                    }
                </div>

                <div class="alert alert-light border mt-3 small mb-0" id="emptyCompetenceMessage" style="display:none;">
                    <i class="fas fa-info-circle me-2"></i>Aucune compétence disponible pour ce grade.
                </div>
            </div>

            <!-- Actions -->
            <div class="ey-actions-bar">
                <a asp-action="Index" asp-route-collaborateurId="@ViewBag.CollaborateurId" class="ey-btn-premium ey-btn-ghost">
                    <i class="fas fa-times"></i> Annuler
                </a>
                <div class="ey-actions-right">
                    <button type="submit" class="ey-btn-premium ey-btn-primary">
                        <i class="fas fa-check"></i> Créer les compétences
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/rh-dynamic-forms.js" asp-append-version="true"></script>
    <script>
        // Fonction pour gérer la sélection visuelle des compétences
        function toggleCompetence(card) {
            const checkbox = card.querySelector('.competence-choice');
            checkbox.checked = !checkbox.checked;
            card.classList.toggle('selected', checkbox.checked);
            updateCounter();
        }

        // Mise à jour du compteur avec animation
        function updateCounter() {
            const count = document.querySelectorAll('.competence-choice:checked').length;
            const counterEl = document.getElementById('competenceCount');
            counterEl.textContent = count;
            counterEl.parentElement.classList.add('ey-counter-animate');
            setTimeout(() => counterEl.parentElement.classList.remove('ey-counter-animate'), 400);
        }

        // Initialisation
        document.addEventListener('DOMContentLoaded', function() {
            // Synchroniser l'état visuel avec les checkboxes
            document.querySelectorAll('.competence-choice').forEach(function(cb) {
                if (cb.checked) {
                    cb.closest('.ey-competence-card').classList.add('selected');
                }
            });
            updateCounter();
        });
    </script>
}
