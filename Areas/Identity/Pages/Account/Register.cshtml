@page
@model RegisterModel
@{
    ViewData["Title"] = "Créer un compte";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-ey.css" asp-append-version="true" />
}

<div class="auth-ey-wrapper">
    <div class="auth-ey-card">
        <div class="auth-ey-logo">
            <img src="~/images/ey-logo.png" alt="EY Logo" />
            <h1 class="auth-ey-title">Créer un compte</h1>
            <p class="auth-ey-subtitle">Rejoignez le Portail RH EY</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Prenom" class="auth-ey-label">Prénom</label>
                    <input asp-for="Input.Prenom" class="form-control auth-ey-input" placeholder="Prénom" />
                    <span asp-validation-for="Input.Prenom" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Nom" class="auth-ey-label">Nom</label>
                    <input asp-for="Input.Nom" class="form-control auth-ey-input" placeholder="Nom" />
                    <span asp-validation-for="Input.Nom" class="text-danger"></span>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Input.Email" class="auth-ey-label">Email EY</label>
                <input asp-for="Input.Email" class="form-control auth-ey-input" autocomplete="username" aria-required="true" placeholder="prenom.nom@ey.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Input.Password" class="auth-ey-label">Mot de passe</label>
                <input asp-for="Input.Password" class="form-control auth-ey-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            
            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="auth-ey-label">Confirmer le mot de passe</label>
                <input asp-for="Input.ConfirmPassword" class="form-control auth-ey-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            
            <button id="registerSubmit" type="submit" class="btn-ey-auth">
                <i class="fas fa-user-plus me-2"></i>Créer mon compte
            </button>

            <div class="auth-ey-divider">
                <span>ou</span>
            </div>

            <div class="auth-ey-footer">
                <p>
                    <a asp-page="./Login" class="auth-ey-link">
                        <i class="fas fa-sign-in-alt me-1"></i>J'ai déjà un compte
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
